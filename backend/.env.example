# ============================================================
#  Mideye Backend – Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database
# Local XAMPP:  DB_HOST=localhost, DB_USER=root, DB_PASSWORD=
# Render/Cloud: fill with your managed MySQL provider credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mideye_db
DB_USER=root
DB_PASSWORD=

# JWT – use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_before_deploying
JWT_EXPIRES_IN=7d
